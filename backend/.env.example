# ==========================================
# 1. SERVER CONFIGURATION
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# 2. DATABASE (Supabase Postgres via Prisma)
# ==========================================
# Used by Prisma Client for standard queries (Connection Pooling)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Used by Prisma CLI for migrations (Direct Connection)
DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ==========================================
# 3. AUTHENTICATION (Supabase)
# ==========================================
SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="eyJhbG..."
# Required for your backend middleware to verify incoming JWTs
SUPABASE_JWT_SECRET="your-super-secret-jwt-token-from-supabase-settings"

# ==========================================
# 4. SQUAD API (Sandbox)
# ==========================================
SQUAD_BASE_URL="https://sandbox-api-d.squadco.com"
SQUAD_PUBLIC_KEY="sandbox_pk_..."
SQUAD_SECRET_KEY="sandbox_sk_..."

# ==========================================
# 5. SECURITY (PII Encryption)
# ==========================================
# A random 32-character string used by your crypto utility to encrypt the BVN
ENCRYPTION_KEY="a-very-secure-32-character-long-string!!"

# ==========================================
# 6. PARTNER API KEYS (Unit 07)
# ==========================================
# Comma-separated list of API keys for external lenders/partners
PARTNER_API_KEYS="lender_key_123,bank_key_456,partner_key_789"